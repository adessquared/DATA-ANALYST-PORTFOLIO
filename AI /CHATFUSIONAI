## 12. Analytical SQL Queries

### Q1: SaaS plan revenue and subscriber distribution

```sql
SELECT
  p.name                                                          AS plan_name,
  p.price_cents / 100                                             AS price_usd,
  COUNT(s.id)                                                     AS total_subscribers,
  SUM(CASE WHEN s.status = 'active'    THEN 1 ELSE 0 END)        AS active,
  SUM(CASE WHEN s.status = 'cancelled' THEN 1 ELSE 0 END)        AS cancelled,
  SUM(CASE WHEN s.status = 'active'    THEN p.price_cents ELSE 0 END) / 100 AS mrr_usd
FROM plans p
LEFT JOIN subscriptions s ON s.plan_id = p.id
GROUP BY p.id, p.name, p.price_cents
ORDER BY p.price_cents DESC;
```

### Q2: Content generation volume and credit consumption by type

```sql
SELECT
  type,
  COUNT(*)                                                        AS total_generated,
  SUM(credits_cost)                                               AS total_credits_used,
  AVG(credits_cost)                                               AS avg_credits_per_generation,
  SUM(CASE WHEN status = 'published' THEN 1 ELSE 0 END)          AS published,
  SUM(CASE WHEN is_flagged = 1        THEN 1 ELSE 0 END)          AS flagged
FROM contents
GROUP BY type
ORDER BY total_generated DESC;
```

### Q3: Social post performance funnel by platform

```sql
SELECT
  platform,
  COUNT(*)                                                        AS total_posts,
  SUM(CASE WHEN status = 'sent'      THEN 1 ELSE 0 END)          AS sent,
  SUM(CASE WHEN status = 'failed'    THEN 1 ELSE 0 END)          AS failed,
  SUM(CASE WHEN status = 'queued'    THEN 1 ELSE 0 END)          AS queued,
  SUM(CASE WHEN status = 'scheduled' THEN 1 ELSE 0 END)          AS scheduled,
  ROUND(SUM(CASE WHEN status = 'sent' THEN 1 ELSE 0 END) * 100.0
        / COUNT(*), 1)                                            AS success_rate_pct
FROM social_posts
GROUP BY platform
ORDER BY total_posts DESC;
```

### Q4: Analytics funnel — impressions to conversions by user

```sql
SELECT
  u.name                                                          AS user_name,
  SUM(ad.impressions)                                             AS total_impressions,
  SUM(ad.clicks)                                                  AS total_clicks,
  SUM(ad.conversions)                                             AS total_conversions,
  SUM(ad.revenue)                                                 AS total_revenue_usd,
  ROUND(SUM(ad.clicks) * 100.0 / NULLIF(SUM(ad.impressions), 0), 2) AS ctr_pct,
  ROUND(SUM(ad.conversions) * 100.0 / NULLIF(SUM(ad.clicks), 0), 2) AS cvr_pct
FROM users u
JOIN analytics_daily ad ON ad.user_id = u.id
GROUP BY u.id, u.name
ORDER BY total_revenue_usd DESC;
```

### Q5: Affiliate funnel — clicks to paid commissions

```sql
SELECT
  u.name                                                          AS affiliate_name,
  al.clicks,
  al.conversions,
  ROUND(al.conversions * 100.0 / NULLIF(al.clicks, 0), 1)        AS conversion_rate_pct,
  COUNT(ac.id)                                                    AS commission_records,
  SUM(ac.amount) / 100                                            AS total_commission_usd,
  SUM(CASE WHEN ac.status = 'pending' THEN ac.amount ELSE 0 END) / 100 AS pending_usd,
  SUM(CASE WHEN ac.status = 'paid'    THEN ac.amount ELSE 0 END) / 100 AS paid_usd
FROM affiliates a
JOIN users u              ON u.id = a.user_id
JOIN affiliate_links al   ON al.user_id = a.user_id
LEFT JOIN affiliate_commissions ac ON ac.user_id = a.user_id
GROUP BY a.id, u.name, al.clicks, al.conversions
ORDER BY total_commission_usd DESC;
```

### Q6: Workflow health — execution success rate and duration

```sql
SELECT
  w.name                                                          AS workflow_name,
  w.steps_count,
  COUNT(wr.id)                                                    AS total_runs,
  SUM(CASE WHEN wr.status = 'completed' THEN 1 ELSE 0 END)       AS successful,
  SUM(CASE WHEN wr.status = 'failed'    THEN 1 ELSE 0 END)       AS failed,
  ROUND(SUM(CASE WHEN wr.status = 'completed' THEN 1 ELSE 0 END)
        * 100.0 / COUNT(wr.id), 1)                               AS success_rate_pct,
  ROUND(AVG(TIMESTAMPDIFF(SECOND, wr.started_at, wr.finished_at)), 1) AS avg_duration_sec
FROM workflows w
LEFT JOIN workflow_runs wr ON wr.workflow_id = w.id
WHERE w.deleted_at IS NULL
GROUP BY w.id, w.name, w.steps_count
ORDER BY total_runs DESC;
```

### Q7: Content version depth — how many revisions per content piece

```sql
SELECT
  c.type,
  c.status,
  COUNT(DISTINCT c.id)                                            AS content_pieces,
  AVG(c.version)                                                  AS avg_versions,
  MAX(c.version)                                                  AS max_versions,
  SUM(c.credits_cost)                                             AS total_credits_spent
FROM contents c
GROUP BY c.type, c.status
ORDER BY avg_versions DESC;
```

